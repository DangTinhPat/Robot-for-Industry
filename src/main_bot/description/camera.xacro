<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ─── Camera dimensions ─── -->
  <xacro:property name="cam_size_x"  value="0.020"/>  <!-- depth (trục X, hướng nhìn) -->
  <xacro:property name="cam_size_y"  value="0.030"/>  <!-- chiều rộng -->
  <xacro:property name="cam_size_z"  value="0.025"/>  <!-- chiều cao -->
  <xacro:property name="cam_mass"    value="0.050"/>

  <!--
    Vị trí tương đối so với base_link (tâm thân xe):
      X = chassis_length/2   → mặt trước thân xe
      Y = 0                  → trục đối xứng Y
      Z = chassis_height/2 + 0.05  → 5 cm trên mặt trên thân xe
    Các biến chassis_length, chassis_height được khai báo trong robot_core.xacro.
  -->
  <xacro:property name="cam_x" value="${chassis_length / 2}"/>
  <xacro:property name="cam_y" value="0"/>
  <xacro:property name="cam_z" value="${chassis_height / 2 + 0.05}"/>

  <!-- ─── camera_link ─── -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="${cam_size_x} ${cam_size_y} ${cam_size_z}"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="${cam_size_x} ${cam_size_y} ${cam_size_z}"/>
      </geometry>
    </collision>
    <xacro:inertial_box mass="${cam_mass}"
                        x="${cam_size_x}" y="${cam_size_y}" z="${cam_size_z}">
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </xacro:inertial_box>
  </link>

  <!-- base_link → camera_link -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="${cam_x} ${cam_y} ${cam_z}" rpy="0 0 0"/>
  </joint>

  <!--
    Optical frame: xoay từ hệ robot (X=tiến, Y=trái, Z=lên)
    sang hệ quang học ROS tiêu chuẩn (Z=tiến, X=phải, Y=xuống).
    Convention: rpy = (-pi/2, 0, -pi/2)
  -->
  <link name="camera_link_optical"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_link_optical"/>
    <origin xyz="0 0 0" rpy="${-pi/2} 0 ${-pi/2}"/>
  </joint>

  <!-- ─── Gazebo Harmonic sensor ─── -->
  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <always_on>true</always_on>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <topic>/camera</topic>
      <camera name="camera">
        <horizontal_fov>1.089</horizontal_fov>   <!-- ~62° FOV -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>8.0</far>
        </clip>
        <optical_frame_id>camera_link_optical</optical_frame_id>
      </camera>
    </sensor>
  </gazebo>

</robot>
